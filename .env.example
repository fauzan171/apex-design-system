# Apex Ferro ERP Dashboard - Environment Configuration
# Copy this file to .env.local and update values

# API Configuration
# Set to your backend API URL (e.g., http://localhost:8787)
# Leave empty or unset to use mock data only
VITE_API_URL=http://localhost:8787

# Mock Data Toggle
# Set to "true" to use mock data even when VITE_API_URL is set
# Set to "false" to use real API calls
VITE_USE_MOCK_DATA=true

# Feature Flags (optional)
# VITE_ENABLE_DEBUG=false
# VITE_ENABLE_DEVTOOLS=true

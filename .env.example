# Apex Ferro ERP Dashboard - Environment Configuration
# Copy this file to .env.local for local development

# NOTE: For production/staging, API proxy is handled by Cloudflare Worker.
# Set API_URL in Cloudflare Dashboard: Workers > apex-design-system > Settings > Variables
# - Staging: API_URL = "https://appex-erp-be-staging.itobsidianmuda.workers.dev"
# - Production: API_URL = "https://appex-erp-be-production.itobsidianmuda.workers.dev"

# Local Development Only (optional)
# Vite dev server will proxy /api requests to this URL
# VITE_API_URL=http://localhost:8787
